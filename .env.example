# PostgreSQL接続URL (Vercel PostgresまたはNeonまたはSupabase)
DATABASE_URL="postgresql://user:password@host:5432/plato_event_proof_lab?sslmode=require"

# セッション署名秘密鍵 (最低32文字のランダム文字列)
# 生成例: openssl rand -base64 32
SESSION_SECRET="your-minimum-32-char-random-secret-here"

# APIキー暗号化鍵 (32バイト = base64で44文字)
# 生成例: openssl rand -base64 32
ENCRYPTION_KEY="your-32-byte-base64-encoded-key-here=="

# 管理者ブートストラップメール (初回seed実行でこのメールに管理者権限が付与される)
ADMIN_BOOTSTRAP_EMAIL="admin@example.com"

# アプリURL (CSRF保護のOriginチェックに使用)
APP_URL="https://your-app.vercel.app"

# レート制限設定
RATE_LIMIT_WINDOW="60000"
RATE_LIMIT_MAX="100"

# 外部AI (オプション: ユーザーが自分のAPIキーを登録する場合のベースURL)
# OPENAI_API_BASE="https://api.openai.com/v1"

# Next.js環境
NODE_ENV="production"
